# ============================================================================
# Unnati Retail OS — Environment Configuration Template
# Copyright (c) 2026 Walsong Group. All rights reserved.
#
# Instructions:
#   cp .env.example .env
#   Fill in all values marked with <CHANGE_ME>
# ============================================================================

# ── Go API ────────────────────────────────────────────────────────────────
PORT=8080
GIN_MODE=release

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DB=unnati
POSTGRES_USER=unnati
POSTGRES_PASSWORD=<CHANGE_ME_strong_password_here>

DATABASE_URL=postgres://unnati:<CHANGE_ME>@postgres:5432/unnati?sslmode=disable

# Run DB migrations on startup (true in production)
RUN_MIGRATIONS=true

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<CHANGE_ME_redis_password>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Security ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=<CHANGE_ME_generate_with_openssl>

# ── Tailscale VPN ─────────────────────────────────────────────────────────
# Get from: https://login.tailscale.com/admin/settings/keys
# Use an auth key with "Reusable" and "Ephemeral" settings OFF for servers
TAILSCALE_AUTH_KEY=tskey-auth-<CHANGE_ME>

# ── Shop Configuration ────────────────────────────────────────────────────
SHOP_NAME=My Hardware Store
SHOP_ADDRESS=New Road, Kathmandu, Nepal
SHOP_PHONE=+977-01-4XXXXXX
SHOP_PAN=<your_PAN_number>
SHOP_VAT=<your_VAT_number>

# ── Fonepay ───────────────────────────────────────────────────────────────
FONEPAY_MERCHANT_CODE=<CHANGE_ME>
FONEPAY_MERCHANT_NAME=<CHANGE_ME>
FONEPAY_TERMINAL_ID=<CHANGE_ME>

# ── pgAdmin (dev only) ────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@unnati.local
PGADMIN_PASSWORD=<CHANGE_ME>
